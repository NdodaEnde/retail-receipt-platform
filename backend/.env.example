# ── KlpIT Backend Environment Variables ──
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Supabase (PostgreSQL database + file storage) ──
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-service-role-key

# ── WhatsApp Business Cloud API ──
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_whatsapp_business_account_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=klpit_webhook_2026
WHATSAPP_API_VERSION=v23.0

# ── LandingAI ADE (Receipt OCR) ──
LANDINGAI_API_KEY=your_landingai_api_key

# ── Google Maps (Shop geocoding) ──
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── OpenAI (optional — only needed when Qdrant Cloud is enabled) ──
OPENAI_API_KEY=your_openai_api_key

# ── CORS ──
CORS_ORIGINS=http://localhost:3000
