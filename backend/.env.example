# Receipt-to-Win Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Database
MONGO_URL=mongodb://localhost:27017
DB_NAME=test_database
CORS_ORIGINS=*

# WhatsApp Cloud API (Meta Business Platform)
# Get these from: https://developers.facebook.com/apps/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WABA_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_API_VERSION=v20.0
WHATSAPP_TEMPLATE_NAME=your_template_name
WHATSAPP_TEMPLATE_LANGUAGE=en

# LandingAI ADE for Receipt OCR
# Get from: https://landing.ai/
LANDINGAI_API_KEY=your_landingai_api_key

# OpenAI (for embeddings/vector search)
# Get from: https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key

# Google Maps Geocoding API
# Get from: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
